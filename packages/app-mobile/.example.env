# API
# Use your local machine's IP address (run: hostname -I | awk '{print $1}')
# Do NOT use 10.0.2.2 as the backend listens on IPv6 by default
EXPO_PUBLIC_API_BASE_URL=http://<local-ip>:3100/api

# Keycloak
EXPO_PUBLIC_KEYCLOAK_URL=http://<local-ip>:3380
EXPO_PUBLIC_KEYCLOAK_REALM="FIT Log"
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=fit-log-mobile
