{
  "name": "@jrposada/fit-log-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "author": {
    "email": "jrposada.dev@gmail.com",
    "name": "Javier Rodriguez Posada"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jrposada/fit-log.git"
  },
  "engines": {
    "node": "^22",
    "pnpm": "^10"
  },
  "scripts": {
    "build": "tsc",
    "dev:db": "docker-compose --project-name fit-log up -d",
    "dev:server": "tsx watch src/server.ts",
    "dev": "run-p dev:*",
    "format": "prettier . --write",
    "start": "node dist/server.js",
    "lint:eslint": "eslint .",
    "lint:format": "prettier . --check",
    "lint:types": "tsc --noEmit",
    "lint": "run-p lint:*"
  },
  "dependencies": {
    "@jrposada/fit-log-shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "mongoose": "9.0.0",
    "sharp": "^0.34.5",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/uuid": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "globals": "catalog:",
    "npm-run-all": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
