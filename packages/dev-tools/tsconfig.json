{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "noImplicitReturns": true,

    "types": ["node"],

    "paths": {
      "@backend/*": ["../backend/src/*"],
      "@moonboard-sdk/*": ["../moonboard-sdk/src/*"],
      "@shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "bin"]
}
