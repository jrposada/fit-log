{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "nodenext",
    "lib": ["ES2020"],
    "skipLibCheck": true,

    /* Module resolution */
    "composite": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",

    /* Linting */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "noImplicitReturns": true,

    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
